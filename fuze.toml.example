# Fuze AI Configuration
# Copy this file to fuze.toml in your project root.

[defaults]
maxRetries = 3
timeout = 30000           # ms
maxTokensPerRun = 100000  # total input+output tokens per run
maxWallClockMs = 600000   # wall-clock ceiling per run (ms)
maxIterations = 25
onLoop = "kill"           # "kill" | "warn" | "skip"
traceOutput = "./fuze-traces.jsonl"

[loopDetection]
windowSize = 5
repeatThreshold = 3
maxFlatSteps = 4
