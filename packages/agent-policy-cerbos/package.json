{
  "name": "@fuze-ai/agent-policy-cerbos",
  "version": "0.1.0",
  "description": "Cerbos-compatible PolicyEngine adapter for the Fuze Agent framework. Phase 1 ships a YAML+CEL evaluator; Phase 2 swaps in @cerbos/embedded WASM with a stable surface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@fuze-ai/agent": "0.1.0",
    "js-yaml": "^4.1.0"
  },
  "optionalDependencies": {
    "@cerbos/embedded": "^0.20.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
