    "@connectrpc/connect-web": "^2.1.1",
    "@fuze-ai/agent": "0.1.0"
  },
  "optionalDependencies": {
    "e2b": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
