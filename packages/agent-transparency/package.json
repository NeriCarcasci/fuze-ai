{
  "name": "@fuze-ai/agent-transparency",
  "version": "0.1.0",
  "description": "Append-only transparency log for Fuze Agent run-roots. Anchors signed run-roots to a public log so any third party can prove a run-root existed before time T.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@fuze-ai/agent": "0.1.0"
  },
  "optionalDependencies": {
    "@sigstore/rekor": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
